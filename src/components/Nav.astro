---
import { withBase, withoutBase } from "../lib/routes.js";

const currentPath = withoutBase(Astro.url.pathname).replace(/\/index\.html$/, "/");

const links = [
  { href: "/", label: "About Me" },
  { href: "/work/", label: "Work Samples" },
];

const isActive = (href) => {
  const url = new URL(href, "https://example.com");
  const path = url.pathname;

  if (url.hash) {
    return false;
  }

  if (path === "/") {
    return currentPath === "/";
  }

  return currentPath.startsWith(path);
};
---

<nav class="site-nav" id="primary-navigation" aria-label="Primary navigation">
  {
    links.map((link) => {
      const active = isActive(link.href);

      return active ? (
        <span class="nav-current" aria-current="page">
          {link.label}
        </span>
      ) : (
        <a href={withBase(link.href)}>
          {link.label}
        </a>
      );
    })
  }
</nav>
