---
import { withBase } from "../lib/routes.js";

const {
  title,
  buttonHref,
  buttonText,
  id,
  copyValue,
  copiedText = "Copied",
  secondaryHref,
  secondaryText,
} = Astro.props;
---

<section class="contact-panel" id={id}>
  <div class="section">
    <h2>{title}</h2>
    <p>
      <slot />
    </p>
    <div class="button-row">
      {
        copyValue ? (
          <button
            class="button primary"
            type="button"
            data-copy-value={copyValue}
            data-copied-text={copiedText}
            data-default-text={buttonText}
            aria-live="polite"
          >
            {buttonText}
          </button>
        ) : (
          <a class="button primary" href={withBase(buttonHref)}>{buttonText}</a>
        )
      }
      {
        secondaryHref && secondaryText && (
          <a class="button secondary" href={withBase(secondaryHref)}>{secondaryText}</a>
        )
      }
    </div>
  </div>
</section>

<script>
  const copyButtons = document.querySelectorAll("[data-copy-value]");

  const copyWithFallback = async (value) => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(value);
      return;
    }

    const textarea = document.createElement("textarea");
    textarea.value = value;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.opacity = "0";
    document.body.append(textarea);
    textarea.select();
    document.execCommand("copy");
    textarea.remove();
  };

  const lockButtonWidth = (button) => {
    const currentText = button.textContent;
    const defaultText = button.getAttribute("data-default-text") || currentText;

    button.textContent = defaultText;
    button.style.width = "auto";
    button.style.width = `${Math.ceil(button.getBoundingClientRect().width)}px`;
    button.textContent = currentText;
  };

  copyButtons.forEach((button) => {
    lockButtonWidth(button);
    document.fonts?.ready.then(() => lockButtonWidth(button));

    let resetTimer;

    button.addEventListener("click", async () => {
      const value = button.getAttribute("data-copy-value");
      const defaultText = button.getAttribute("data-default-text") || button.textContent;
      const copiedMessage = button.getAttribute("data-copied-text") || "Copied";

      if (!value || !defaultText) {
        return;
      }

      try {
        await copyWithFallback(value);
        button.textContent = copiedMessage;
        button.classList.add("is-copied");
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.textContent = defaultText;
          button.classList.remove("is-copied");
        }, 1800);
      } catch {
        button.textContent = "Copy failed";
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          button.textContent = defaultText;
        }, 1800);
      }
    });
  });
</script>
