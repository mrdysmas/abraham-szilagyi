---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles.css";

interface Props {
  title: string;
  description: string;
  footerTagline: string;
}

const { title, description, footerTagline } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:inline>
      .site-header {
        background: rgba(21, 16, 12, 0.9);
        border-bottom: 1px solid #443426;
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .nav-shell {
        align-items: center;
        display: flex;
        gap: 28px;
        justify-content: space-between;
        margin: 0 auto;
        max-width: 1120px;
        min-height: 96px;
        padding-left: 24px;
        padding-right: 24px;
      }

      .brand strong {
        font-size: 1.45rem;
        font-weight: 720;
        line-height: 1.1;
      }

      .site-nav {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
      }

      .site-nav a,
      .site-nav .nav-current {
        border: 1px solid transparent;
        border-radius: 999px;
        color: #c8b8a4;
        display: inline-block;
        font-size: 1.1rem;
        line-height: 1.12;
        padding: 10px 14px;
        text-decoration: none;
      }

      .site-nav .nav-current {
        background: #211811;
        border-color: #443426;
        color: #f7efe5;
      }

      @media (max-width: 680px) {
        .nav-shell {
          display: grid;
          grid-template-columns: minmax(0, 1fr) auto;
          min-height: 70px;
          padding: 10px 18px;
        }

        .site-nav {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <slot />
    <Footer tagline={footerTagline} />
  </body>
</html>
