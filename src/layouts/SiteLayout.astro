---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles.css";

interface Props {
  title: string;
  description: string;
  footerTagline: string;
}

const { title, description, footerTagline } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      document.documentElement.classList.add("js-enabled");
    </script>
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer tagline={footerTagline} />
    <script is:inline>
      (() => {
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (reduceMotion) {
          return;
        }

        let frame = 0;
        let fadeTimer = 0;
        let x = window.innerWidth / 2;
        let y = window.innerHeight / 2;

        const updateSpotlight = () => {
          frame = 0;
          document.body.style.setProperty("--spotlight-x", `${x}px`);
          document.body.style.setProperty("--spotlight-y", `${y}px`);
          document.body.style.setProperty("--spotlight-opacity", "1");
        };

        const scheduleSpotlight = (clientX, clientY) => {
          x = clientX;
          y = clientY;
          window.clearTimeout(fadeTimer);
          if (!frame) {
            frame = window.requestAnimationFrame(updateSpotlight);
          }
        };

        const fadeSpotlight = () => {
          fadeTimer = window.setTimeout(() => {
            document.body.style.setProperty("--spotlight-opacity", "0");
          }, 160);
        };

        window.addEventListener("pointermove", (event) => {
          scheduleSpotlight(event.clientX, event.clientY);
        }, { passive: true });

        window.addEventListener("pointerup", fadeSpotlight, { passive: true });
        window.addEventListener("pointercancel", fadeSpotlight, { passive: true });
        window.addEventListener("pointerleave", fadeSpotlight, { passive: true });

        window.addEventListener("touchmove", (event) => {
          const touch = event.touches[0];

          if (touch) {
            scheduleSpotlight(touch.clientX, touch.clientY);
          }
        }, { passive: true });

        window.addEventListener("touchend", fadeSpotlight, { passive: true });
        window.addEventListener("touchcancel", fadeSpotlight, { passive: true });
      })();
    </script>
  </body>
</html>
